+  # Cpu Event handler Guid
+  gArmCpuEventHandlerGuid = { 0x2c1b3bfc, 0x42cd, 0x4a66, { 0xac, 0xd1, 0xa4, 0xd1, 0x63, 0xe9, 0x90, 0xf6 }}
