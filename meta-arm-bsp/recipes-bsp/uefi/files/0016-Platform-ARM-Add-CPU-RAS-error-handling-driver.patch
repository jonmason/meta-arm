+
+[Defines]
+  DEC_SPECIFICATION              = 0x0001001B
+  PACKAGE_NAME                   = CpuMm
+  PACKAGE_GUID                   = b6b5e2a0-ca32-4881-90ee-cbdbcf349b3e
+  PACKAGE_VERSION                = 0.1
+
+[Guids]
