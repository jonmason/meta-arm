diff --git a/Platform/ARM/SgiPkg/Library/PcieAcpiTableGeneratorLib/PcieCxlSsdtTemplate.asl b/Platform/ARM/SgiPkg/Library/PcieAcpiTableGeneratorLib/PcieCxlSsdtTemplate.asl
