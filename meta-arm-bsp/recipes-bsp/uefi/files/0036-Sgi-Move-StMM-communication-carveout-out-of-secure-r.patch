+++ b/Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1/Einj.aslc
@@ -53,7 +53,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         32,
         0,
         EFI_ACPI_6_4_DWORD,
-        0xFF610000
+        0xFFE10000
       },   // Register region (GAR)
       PLATFORM_ERROR_TYPE_SUPPORTED,   // Supported Error Types by platform (Processor, Vendor)
       0xffffffffffffffff    // Register region Mask
@@ -70,7 +70,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         64,
         0,
         EFI_ACPI_6_4_QWORD,
-        0xFF610000
+        0xFFE10000
       },
       0x0000000000000000,   // Value
       0xffffffffffffffff    // Register region Mask
@@ -87,7 +87,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         64,
         0,
         EFI_ACPI_6_4_QWORD,
-        0xFF610100
+        0xFFE10100
       },
       0x0000000000000000,   // Value
       0xffffffffffffffff    // Register region Mask
@@ -104,7 +104,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         64,
         0,
         EFI_ACPI_6_4_QWORD,
-        0xFF610250
+        0xFFE10250
       },
       0x0000000000000000,   // Value
       0xffffffffffffffff    // Register region Mask
@@ -121,7 +121,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         64,
         0,
         EFI_ACPI_6_4_QWORD,
-        0xFF610400
+        0xFFE10400
       },
       0x0000000000000000,   // Value
       0xffffffffffffffff    // Register region Mask
@@ -138,7 +138,7 @@ STATIC EFI_ACPI_6_4_ERROR_INJECTION_TABLE Einj = {
         64,
         0,
         EFI_ACPI_6_4_QWORD,
-        0xFF610200
+        0xFFE10200
       },
       FixedPcdGet64 (PcdEinjTriggerActionBase),   // Value
       0xffffffffffffffff    // Register region Mask
diff --git a/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc b/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
index c01e0b02be3a..104bbc0c2666 100644
--- a/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
+++ b/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
@@ -234,7 +234,7 @@
 !if $(EDK2_SPMC_AT_EL2) == TRUE
   gArmTokenSpaceGuid.PcdMmBufferBase|0xF3200000
 !else
-  gArmTokenSpaceGuid.PcdMmBufferBase|0xFF600000
+  gArmTokenSpaceGuid.PcdMmBufferBase|0xFFE00000
 !endif
   gArmTokenSpaceGuid.PcdMmBufferSize|0x10000
 
@@ -247,9 +247,9 @@
 
 !if $(EDK2_ERROR_INJ_EN) == TRUE
   ## Error Injection Instruction Memory Space
-  gArmSgiTokenSpaceGuid.PcdEinjInstBufferBase|0xFF610000
+  gArmSgiTokenSpaceGuid.PcdEinjInstBufferBase|0xFFE10000
   gArmSgiTokenSpaceGuid.PcdEinjInstBufferSize|0x10000
-  gArmSgiTokenSpaceGuid.PcdEinjTriggerActionBase|0xFF611000
+  gArmSgiTokenSpaceGuid.PcdEinjTriggerActionBase|0xFFE11000
