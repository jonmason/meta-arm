+#define PCIE_MCFG_TABLE_GENERATOR_H
+
+#include <Library/BaseLib.h>
+
+#include <SgiPlatform.h>
+
+EFI_STATUS
+EFIAPI
+GenerateAndInstallMcfgTable (
+    IN SGI_PCIE_IO_BLOCK_LIST * CONST IoBlockList
+    );
+
+#endif /* PCIE_MCFG_TABLE_GENERATOR_H */
