+      if (HobIoBlockList == NULL) {
+        DEBUG ((DEBUG_ERROR, "PCIe MMap HOB creation failed\n"));
+        ASSERT (FALSE);
+        return EFI_OUT_OF_RESOURCES;
+      }
+      CopyMem (HobIoBlockList, IoBlockListHead, IoBlockList.TableSize);
+    }
+  }
+
