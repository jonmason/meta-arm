From 42526fe8a489a2d1b02f598b66fd42d848aeaa8c Mon Sep 17 00:00:00 2001
From: Omkar Anand Kulkarni <omkar.kulkarni@arm.com>
Date: Fri, 16 Sep 2022 12:57:38 +0530
Subject: [PATCH 22/78] Platform/Sgi: Add Kernel first support on RD-N2-Cfg1
 platform

Introduce compile time flags to switch between firmware and kernel first
error handling. Firmware first support is enabled by default by the
build system.

Signed-off-by: Omkar Anand Kulkarni <omkar.kulkarni@arm.com>
Change-Id: I7bca83550a6c512a85322244e7cc3cb120c97a26
---
 .../PlatformErrorHandlerDxeRas.inf            | 59 +++++++++++++++++++
 Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc     |  4 ++
 Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.fdf.inc |  7 +++
 Platform/ARM/SgiPkg/SgiPlatform.dsc.inc       | 11 ++++
 Platform/ARM/SgiPkg/SgiPlatform.fdf           |  5 ++
 5 files changed, 86 insertions(+)
 create mode 100644 Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf

diff --git a/Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf b/Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf
new file mode 100644
index 000000000000..add8b9dbf099
--- /dev/null
+++ b/Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf
@@ -0,0 +1,59 @@
+## @file
+#  Dxe driver to enable kernel first error handling.
+#
+#  This driver installs ACPI tables required to perform kernel first error
+#  handling.
+#
+#  Copyright (c) 2022, ARM Limited. All rights reserved.
+#  SPDX-License-Identifier: BSD-2-Clause-Patent
+#
+##
+
+[Defines]
+  INF_VERSION                    = 0x0001001B
+  BASE_NAME                      = PlatformErrorHandlerDxe
+  FILE_GUID                      = a3187ea4-feb4-415f-b11e-2312623ffa6f
+  MODULE_TYPE                    = DXE_DRIVER
+  VERSION_STRING                 = 1.0
+  ENTRY_POINT                    = PlatformErrorHandlerEntryPoint
+
+[Sources.common]
+  PlatformErrorHandlerDxe.c
+
+[Packages]
+  ArmPlatformPkg/ArmPlatformPkg.dec
+  EmbeddedPkg/EmbeddedPkg.dec
+  MdeModulePkg/MdeModulePkg.dec
+  MdePkg/MdePkg.dec
+  Platform/ARM/SgiPkg/SgiPlatform.dec
+
+[LibraryClasses]
+  AcpiLib
+  BaseLib
+  BaseMemoryLib
+  DebugLib
+  UefiDriverEntryPoint
+
+[Guids]
+  gArmSgiAcpiTablesGuid
+
+[Protocols]
+  gEfiAcpiTableProtocolGuid         ## PROTOCOL ALWAYS_CONSUMED
+  gHestTableProtocolGuid            ## PROTOCOL ALWAYS_CONSUMED
+
+[FixedPcd]
+  gArmSgiTokenSpaceGuid.PcdEinjInstBufferBase
+  gArmSgiTokenSpaceGuid.PcdEinjInstBufferSize
+  gArmSgiTokenSpaceGuid.PcdEinjTriggerActionBase
+
+  gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultCreatorId
+  gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultCreatorRevision
+  gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultOemId
+  gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultOemRevision
+  gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultOemTableId
+
+[FeaturePcd]
+  gArmSgiTokenSpaceGuid.PcdEinjSupported
+
+[Depex]
+  TRUE
diff --git a/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc b/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc
index 1d3f51acfc2c..2e9bb01a58e3 100644
--- a/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc
+++ b/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc
@@ -57,8 +57,12 @@
 ################################################################################
 
 [Components.common]
+!if $(EDK2_ENABLE_KERNEL_FIRST) == TRUE
+  Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTablesRas.inf
+!else
 !if $(EDK2_ERROR_INJ_EN) == TRUE
   Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTablesEinj.inf
 !else
   Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTables.inf
 !endif
+!endif
diff --git a/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.fdf.inc b/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.fdf.inc
index a726669765ae..2f6cf29adb5d 100644
--- a/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.fdf.inc
+++ b/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.fdf.inc
@@ -9,8 +9,15 @@
 # Per-platform additional content of the DXE phase firmware volume
 
   # ACPI support
+!if $(EDK2_ENABLE_FIRMWARE_FIRST) == TRUE
+  INF RuleOverride=ACPITABLE Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTables.inf
+!endif
+!if $(EDK2_ENABLE_KERNEL_FIRST) == TRUE
+  INF RuleOverride=ACPITABLE Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTablesRas.inf
+!else
 !if $(EDK2_ERROR_INJ_EN) == TRUE
   INF RuleOverride=ACPITABLE Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTablesEinj.inf
 !else
   INF RuleOverride=ACPITABLE Platform/ARM/SgiPkg/AcpiTables/RdN2Cfg1AcpiTables.inf
 !endif
+!endif
diff --git a/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc b/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
index f58d20520679..e333154fadcf 100644
--- a/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
+++ b/Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
@@ -25,6 +25,12 @@
   # To allow firmware first error handling, set this to TRUE.
   DEFINE EDK2_ENABLE_GHES_MM                = FALSE
 
+  # To enable firmware first error handling, set this to TRUE.
+  DEFINE EDK2_ENABLE_FIRMWARE_FIRST           = FALSE
+
+  # To allow kernel first error handling, set this to TRUE.
+  DEFINE EDK2_ENABLE_KERNEL_FIRST           = FALSE
+
   # To enable error injection support, set this to TRUE.
   DEFINE EDK2_ERROR_INJ_EN                  = FALSE
 
@@ -334,7 +340,12 @@
   #
   # Platform error handler driver
   #
+!if $(EDK2_ENABLE_FIRMWARE_FIRST) == TRUE
   Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxe.inf
+!endif
+!if $(EDK2_ENABLE_KERNEL_FIRST) == TRUE
+  Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf
+!endif
 
   #
   # FAT filesystem + GPT/MBR partitioning
diff --git a/Platform/ARM/SgiPkg/SgiPlatform.fdf b/Platform/ARM/SgiPkg/SgiPlatform.fdf
index 4803aadbcc75..7aeb462e1be3 100644
--- a/Platform/ARM/SgiPkg/SgiPlatform.fdf
+++ b/Platform/ARM/SgiPkg/SgiPlatform.fdf
@@ -196,7 +196,12 @@ READ_LOCK_STATUS   = TRUE
   #
   # Platform error handler driver
   #
+!if $(EDK2_ENABLE_FIRMWARE_FIRST) == TRUE
   INF Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxe.inf
+!endif
+!if $(EDK2_ENABLE_KERNEL_FIRST) == TRUE
+  INF Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf
+!endif
 
   #
   # Bds
-- 
2.39.5

