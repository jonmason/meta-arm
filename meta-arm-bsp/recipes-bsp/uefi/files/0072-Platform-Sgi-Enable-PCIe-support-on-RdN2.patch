Subject: [PATCH 72/78] Platform/Sgi: Enable PCIe support on RdN2

Enable PCIe support by adding the PCDs required for the platform and
enabling PCIe flag.

Signed-off-by: Nishant Sharma <nishant.sharma@arm.com>
Change-Id: I76d97b9b3659e4b6bd03c44cd5b1c3a83e1c1243
---
 Platform/ARM/SgiPkg/RdN2/RdN2.dsc         | 2 ++
 Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc | 2 ++
 Platform/ARM/SgiPkg/RdN2Cfg2/RdN2Cfg2.dsc | 2 ++
 Platform/ARM/SgiPkg/RdN2Cfg3/RdN2Cfg3.dsc | 2 ++
 4 files changed, 8 insertions(+)

diff --git a/Platform/ARM/SgiPkg/RdN2/RdN2.dsc b/Platform/ARM/SgiPkg/RdN2/RdN2.dsc
index de9a8003aa61..dfa648d950c9 100644
--- a/Platform/ARM/SgiPkg/RdN2/RdN2.dsc
+++ b/Platform/ARM/SgiPkg/RdN2/RdN2.dsc
@@ -31,6 +31,8 @@ DEFINE PCIE_ENABLE             = TRUE
 !include Platform/ARM/SgiPkg/SgiPlatform.dsc.inc
 !include Platform/ARM/SgiPkg/SgiMemoryMap2.dsc.inc
 
+DEFINE PCIE_ENABLE             = TRUE
+
 ################################################################################
 #
 # Pcd Section - list of all EDK II PCD Entries defined by this Platform
diff --git a/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc b/Platform/ARM/SgiPkg/RdN2Cfg1/RdN2Cfg1.dsc
