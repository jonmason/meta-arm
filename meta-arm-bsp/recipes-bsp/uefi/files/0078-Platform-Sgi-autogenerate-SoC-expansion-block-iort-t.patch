+#if SOC_EXPANSION_ENABLED()
+STATIC
+ARM_EFI_ACPI_6_0_IO_REMAPPING_PCIE_SMMU3_NODE *
+UpdateIdMaps(
+    IN OUT IORT_GENERATOR_CONTEXT *Context,
+    IN UINTN Chip,
+    IN UINTN ItsIdx
+    )
+{
+  EFI_ACPI_6_0_IO_REMAPPING_ID_TABLE SmmuIdMap[] = {
+    {
+      DMA_STREAM_ID_BASE(0),
+      (FixedPcdGet32 (PcdIoVirtSocExpBlkDmaNumCh) + 1),
+      DMA_STREAM_ID_BASE(0),
+    },
+    {
+      DMA_STREAM_ID_BASE(1),
+      (FixedPcdGet32 (PcdIoVirtSocExpBlkDmaNumCh) + 1),
+      DMA_STREAM_ID_BASE(1),
+    }
+  };
+  ARM_EFI_ACPI_6_0_IO_REMAPPING_PCIE_SMMU3_NODE * SmmuSocExpNode;
+  ARM_EFI_ACPI_6_0_IO_REMAPPING_ITS_NODE * ItsSocExpNode;
+  EFI_ACPI_6_0_IO_REMAPPING_TABLE * Header;
+  UINT32 *NumIdMappings;
+  UINTN Idx;
+  UINTN TemplateSize;
+
+  Header = Context->Header;
+  ItsSocExpNode = (ARM_EFI_ACPI_6_0_IO_REMAPPING_ITS_NODE *)
+            ((UINT8 *) Context->Header + Context->Header->Header.Length);
+  SmmuSocExpNode = (ARM_EFI_ACPI_6_0_IO_REMAPPING_PCIE_SMMU3_NODE *)
+                    ((UINT8 *)ItsSocExpNode + sizeof(TemplateIts));
+
+  NumIdMappings = &SmmuSocExpNode->SmmuNode.Node.NumIdMappings;
+  TemplateSize =
+    sizeof (TemplateSmmu) + \
+        (sizeof (EFI_ACPI_6_0_IO_REMAPPING_ID_TABLE) * \
+         TemplateSmmu.SmmuNode.Node.NumIdMappings);
+
+  /* Copy ITS Node template. */
+  CopyMem (
+      ItsSocExpNode,
+      &TemplateIts,
+      sizeof(TemplateIts)
+      );
+  ItsSocExpNode->ItsIdentifiers = ItsIdx;
+  Header->Header.Length += sizeof (TemplateIts);
+  Header->NumNodes++;
+
+  /* Copy SMMU node template. */
+  CopyMem (
+      SmmuSocExpNode,
+      &TemplateSmmu,
+      TemplateSize
+      );
+  Header->Header.Length += TemplateSize;
+  SmmuSocExpNode->SmmuNode.Node.Length = TemplateSize;
+  Header->NumNodes++;
+
+  /* Update SMMU ID mappings for the two DMA devices */
+  CopyMem (
+      &SmmuSocExpNode->SmmuIdMap[*NumIdMappings],
+      SmmuIdMap,
+      sizeof (SmmuIdMap)
+      );
+  *NumIdMappings += 2;
+  Header->Header.Length += sizeof (SmmuIdMap);
+  SmmuSocExpNode->SmmuNode.Node.Length += sizeof (SmmuIdMap);
+
+  /* Now update the OutputReference for all SMMU Id mappings */
+  for(Idx = 0; Idx < *NumIdMappings; Idx++) {
+    SmmuSocExpNode->SmmuIdMap[Idx].OutputReference =
+      (UINT32)((UINTN)ItsSocExpNode - (UINTN)Context->Header);
+  }
+
+  /* Update the SMMU base address for each chip */
+  SmmuSocExpNode->SmmuNode.Base =
+    (FixedPcdGet32 (PcdSmmuBase) +
+     (SMMU_REGISTER_BLOCK_SIZE * FixedPcdGet32(PcdIoVirtSocExpBlk0Idx)) +
+     SGI_REMOTE_CHIP_MEM_OFFSET (Chip));
+
+  return SmmuSocExpNode;
+}
+
+STATIC
+VOID
+GenerateSocExpNodes(
+    IN OUT IORT_GENERATOR_CONTEXT *Context,
+    IN     UINTN Chip,
+    IN     UINTN ItsIdx
+    )
+{
+  RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE DmaNodeTemplate = {
+    {
+      ARM_RD_ACPI_IO_VIRT_BLK_DMA_NC_INIT(0),
+      ARM_RD_ACPI_IO_VIRT_BLK_DMA_NC_INIT(1),
+    },
+  };
+  RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE *DmaNode;
+  ARM_EFI_ACPI_6_0_IO_REMAPPING_PCIE_SMMU3_NODE * SmmuSocExpNode;
+  RD_IOVIRT_SOC_EXP_IORT_DMA_NC_NODE * DmaSocExpNode;
+  EFI_ACPI_6_0_IO_REMAPPING_TABLE * Header;
+  UINTN DmaIdx;
+  UINTN NodeIdx;
+  STATIC UINTN DmaNum = 0;
+
+  SmmuSocExpNode = UpdateIdMaps(Context, Chip, ItsIdx);
+  Header = Context->Header;
+  DmaNode = (RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE *)
+    ((UINT8 *) Header + Header->Header.Length);
+
+  CopyMem (
+      DmaNode,
+      &DmaNodeTemplate,
+      sizeof (RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE)
+      );
+  Header->NumNodes++;
+  Header->Header.Length += sizeof(DmaNodeTemplate);
+
+  /* Each SoC expansion block has 2 DMAs */
+  for(DmaIdx = 0; DmaIdx < 2; DmaIdx++) {
+    DmaSocExpNode = &DmaNode->DmaSocExpNode[DmaIdx];
+
+    /* Update the object reference name */
+    AsciiSPrint ((CHAR8 *)DmaSocExpNode->Name, sizeof (DmaSocExpNode->Name),
+                 "\\_SB_.DMA%d", DmaNum++);
+
+    for(NodeIdx = 0; NodeIdx < DmaSocExpNode->DmaNode.Node.NumIdMappings; NodeIdx++) {
+      DmaSocExpNode->DmaIdMap[NodeIdx].OutputReference =
+        (UINT32)((UINTN)SmmuSocExpNode - (UINTN)Header);
+    }
+  }
+}
+
+STATIC
+VOID
+AddSocExpNodes (IORT_GENERATOR_CONTEXT *Context, UINTN NumberHostBridges)
+{
+  UINTN Chip;
+
+  for (Chip = 0; Chip < FixedPcdGet32 (PcdChipCount); Chip++) {
+     GenerateSocExpNodes(Context, Chip, NumberHostBridges + Chip);
+  }
+}
