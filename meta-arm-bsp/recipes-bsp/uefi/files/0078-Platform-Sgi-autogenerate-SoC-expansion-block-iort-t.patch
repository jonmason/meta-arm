+
+#if SOC_EXPANSION_ENABLED()
+  /* Assuming only one node per chip is present on the platform. */
+  Context->MaxTableSize += sizeof (RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE) *
+    FixedPcdGet32 (PcdChipCount);
+  Context->MaxTableSize += sizeof (TemplateIts) * FixedPcdGet32 (PcdChipCount);
+  Context->MaxTableSize +=
+    (sizeof (TemplateSmmu) +
+     (sizeof (EFI_ACPI_6_0_IO_REMAPPING_ID_TABLE) * 2)) *
+    FixedPcdGet32 (PcdChipCount);
+  Context->MaxTableSize +=
+    (sizeof(RD_IOVIRT_SOC_EXP_IO_REMAPPING_DMA_NODE) * 2) *
+    FixedPcdGet32 (PcdChipCount);
+#endif
+
+  Context->TableSize = Context->MaxTableSize;
+
   Context->Header = (EFI_ACPI_6_0_IO_REMAPPING_TABLE *)AllocateZeroPool (Context->MaxTableSize);
   if (Context->Header == NULL) {
     return EFI_OUT_OF_RESOURCES;
@@ -414,7 +597,7 @@ GenerateContext (
     (ARM_EFI_ACPI_6_0_IO_REMAPPING_PCIE_SMMU3_NODE *)((UINT8 *)Context->ItsBase + Context->ItsNodesSize);
