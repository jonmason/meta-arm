   gArmSgiTokenSpaceGuid.PcdIoVirtSocExpBlk0Base|0|UINT64|0x0000002B
   gArmSgiTokenSpaceGuid.PcdIoVirtSocExpBlkUartEnable|0|UINT32|0x0000002C
 
+  # IO virtualization block
+  gArmSgiTokenSpaceGuid.PcdIoVirtBlkCountPerChip|0|UINT32|0x00001023
+  gArmSgiTokenSpaceGuid.PcdIoVirtBlkPortDevIdOffset|0|UINT32|0x00001024
+  gArmSgiTokenSpaceGuid.PcdIoVirtBlkPortPciex40DevIdBase|0|UINT32|0x00001025
