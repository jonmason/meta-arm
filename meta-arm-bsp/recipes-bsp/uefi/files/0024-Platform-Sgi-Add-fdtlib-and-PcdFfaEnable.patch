   gArmSgiTokenSpaceGuid.PcdPlatformVariant|3
 
+  # Disables FFA
+!if $(EDK2_ENABLE_FFA) == FALSE
+  gArmTokenSpaceGuid.PcdFfaEnable|0
+!endif
