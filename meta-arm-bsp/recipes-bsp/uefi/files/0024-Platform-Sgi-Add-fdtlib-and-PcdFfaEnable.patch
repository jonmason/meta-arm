 Platform/ARM/SgiPkg/SgiPlatformMm.dsc.inc                | 6 +++++-
 .../PlatformStandaloneMmPkg/PlatformStandaloneMmRpmb.dsc | 6 ++++--
 9 files changed, 50 insertions(+), 3 deletions(-)

diff --git a/Platform/ARM/SgiPkg/PlatformStandaloneMm2.dsc b/Platform/ARM/SgiPkg/PlatformStandaloneMm2.dsc
index 134daf7f20fb..ef0c333b8eca 100644
