+++ b/Platform/ARM/SgiPkg/RdV3/RdV3.dsc
@@ -45,6 +45,11 @@
   gArmPlatformTokenSpaceGuid.PcdCoreCount|1
   gArmPlatformTokenSpaceGuid.PcdClusterCount|16
 
+# Disables FFA
+!if $(EDK2_ENABLE_FFA) == FALSE
+  gArmTokenSpaceGuid.PcdFfaEnable|0
+!endif
+
