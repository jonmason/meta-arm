+++ b/Platform/ARM/SgiPkg/Drivers/PlatformErrorHandlerDxe/PlatformErrorHandlerDxeRas.inf
@@ -45,6 +45,7 @@
   gArmSgiTokenSpaceGuid.PcdEinjInstBufferBase
   gArmSgiTokenSpaceGuid.PcdEinjInstBufferSize
   gArmSgiTokenSpaceGuid.PcdEinjTriggerActionBase
+  gArmSgiTokenSpaceGuid.PcdEinjSetErrorTypeAddress
 
   gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultCreatorId
   gEfiMdeModulePkgTokenSpaceGuid.PcdAcpiDefaultCreatorRevision
diff --git a/Platform/ARM/SgiPkg/SgiPlatform.dec b/Platform/ARM/SgiPkg/SgiPlatform.dec
index b10def40afaa..0adeafee3886 100644
--- a/Platform/ARM/SgiPkg/SgiPlatform.dec
+++ b/Platform/ARM/SgiPkg/SgiPlatform.dec
@@ -136,5 +136,8 @@
   gArmSgiTokenSpaceGuid.PcdRemoteMemoryBase|0|UINT64|0x00001007
   gArmSgiTokenSpaceGuid.PcdRemoteMemorySize|0|UINT64|0x00001008
 
+  # EINJ Set error type with address
+  gArmSgiTokenSpaceGuid.PcdEinjSetErrorTypeAddress|0x00000000|UINT64|0x00001009
+
 [Ppis]
   gNtFwConfigDtInfoPpiGuid     = { 0x6f606eb3, 0x9123, 0x4e15, { 0xa8, 0x9b, 0x0f, 0xac, 0x66, 0xef, 0xd0, 0x17 } }
