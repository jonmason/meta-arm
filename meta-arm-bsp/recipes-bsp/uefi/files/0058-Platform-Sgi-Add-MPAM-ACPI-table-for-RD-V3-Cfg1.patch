+/** @file
+
+  Memory System Resource Partitioning and Monitoring (MPAM) for RD-V3-Cfg1
+  platform
+
+  MPAM ACPI description for the MSCs (Memory system components) for
+  RD-V3-Cfg1 reference design platform is contained within this file.
+  RD-V3-Cfg1 supports 8 HNF slices, each holding 1 MB of SLC cache. Each of
+  these SLC cache slices in turn holds MPAM MSC controls and associated register
+  files. MPAM has separate secure and non-secure register spaces. Since
+  non-secure OS is generally concerned with the non-secure register space, all
+  of the non-secure nodes should be described within the MPAM ACPI table
+
+  Copyright (c) 2023, Arm Limited. All rights reserved.
+  SPDX-License-Identifier: BSD-2-Clause-Patent
+
+  @par Specification Reference:
+    - MPAM 2.0, Memory System Resource Partitioning and Monitoring
+**/
+
+#include <IndustryStandard/Mpam.h>
+#include <Library/AcpiLib.h>
+#include "SgiAcpiHeader.h"
+
+/*
+ * Macros for RD-V3-Cfg1's MPAM table
+ */
+#define RDV3CFG1_MPAM_MSC_COUNT                                (8)
+#define RDV3CFG1_MPAM_MMIO_SIZE                                (0x1008)
+#define RDV3CFG1_RESOURCES_PER_MSC                             (0x01)
+#define RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE            (0x0)
+#define RDV3CFG1_BASE_ADDRESS(BaseAddress, ChipId)                     \
+  ((SGI_REMOTE_CHIP_MEM_OFFSET(ChipId)) + BaseAddress)
+
+typedef EFI_ACPI_DESCRIPTION_HEADER
+  EFI_ACPI_MPAM_HEADER;
+
+///
+/// MPAM MSC type. For RD-V3-Cfg1, MPAM MSC structure doesn't have any
+/// functional dependency list.
+///
+typedef struct {
+  EFI_ACPI_MPAM_MSC_NODE            Header;
+  EFI_ACPI_MPAM_MSC_RESOURCE        Resource;
+} EFI_ACPI_MPAM_MSC;
+
+///
+/// MPAM ACPI Table
+///
+typedef struct {
+  EFI_ACPI_MPAM_HEADER              Header;
+  EFI_ACPI_MPAM_MSC                 Node[RDV3CFG1_MPAM_MSC_COUNT];
+} EFI_ACPI_MEMORY_SYSTEM_RESOURCE_PARTITIONING_MONITORING_TABLE;
+
+
+STATIC EFI_ACPI_MEMORY_SYSTEM_RESOURCE_PARTITIONING_MONITORING_TABLE Mpam =
+{
+
+  /* EFI_ACPI_MPAM_HEADER */
+  ARM_ACPI_HEADER (
+    EFI_ACPI_MEMORY_SYSTEM_RESOURCE_PARTITIONING_AND_MONITORING_TABLE_SIGNATURE,
+    EFI_ACPI_MEMORY_SYSTEM_RESOURCE_PARTITIONING_MONITORING_TABLE,
+    EFI_ACPI_MEMORY_SYSTEM_RESOURCE_PARTITIONING_AND_MONITORING_TABLE_REVISION
+  ),
+  {
+    /* MPAM_MSC_NODE 1 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x1, RDV3CFG1_BASE_ADDRESS(0x102a41000, 0),
+	 RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+         RDV3CFG1_RESOURCES_PER_MSC,
+         RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 2 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x2, RDV3CFG1_BASE_ADDRESS(0x102a01000, 0),
+         RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+         RDV3CFG1_RESOURCES_PER_MSC,
+         RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 3 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x3, RDV3CFG1_BASE_ADDRESS(0x102641000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 4 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x4, RDV3CFG1_BASE_ADDRESS(0x102601000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 5 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x5, RDV3CFG1_BASE_ADDRESS(0x101a41000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 6 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x6, RDV3CFG1_BASE_ADDRESS(0x101a01000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 7 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x7, RDV3CFG1_BASE_ADDRESS(0x101641000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    },
+
+    /* MPAM_MSC_NODE 8 */
+    {
+      RD_MPAM_MSC_NODE_INIT(0x8, RDV3CFG1_BASE_ADDRESS(0x101601000, 0),
+        RDV3CFG1_MPAM_MMIO_SIZE, 0, RDV3CFG1_MPAM_MSC_COUNT,
+        RDV3CFG1_RESOURCES_PER_MSC,
+        RDV3CFG1_FUNCTIONAL_DEPENDENCY_PER_RESOURCE)
+    }
+  }
+};
+
+VOID* CONST ReferenceAcpiTable = &Mpam;
